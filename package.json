{
  "name": "ray-tracer",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://bengosney.github.io/ray-tracer",
  "dependencies": {
    "@types/react": "^18.0.34",
    "@types/react-dom": "^18.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^4.9.5",
    "wasm-lib": "file:wasm-lib/pkg"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "gh-pages": "^5.0.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "npm run watch:react",
    "build": "npm run build:wasm && npm run build:react",
    "build:react": "webpack --mode production",
    "build:wasm": "cd wasm-lib && wasm-pack build --target web --out-dir pkg",
    "watch:react": "webpack serve --mode development",
    "watch:wasm": "while inotifywait -qr -e close_write --exclude 'pkg/' wasm-lib/; do npm run build:wasm; done"
  }
}
